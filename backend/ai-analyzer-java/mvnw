#!/bin/sh
# Maven Wrapper — script de arranque para Unix/macOS/Linux
# Versión: 3.3.2
# Descarga Maven automáticamente si no está en ~/.m2/wrapper/

set -e

# Resolver directorio del script (sigue symlinks)
if [ -n "$BASH_VERSION" ] || [ -n "$ZSH_VERSION" ]; then
  script_dir="$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")"
else
  script_dir="$(dirname "$0")"
fi

# Leer properties
PROPS_FILE="${script_dir}/.mvn/wrapper/maven-wrapper.properties"
if [ -f "${PROPS_FILE}" ]; then
  DISTRIBUTION_URL=$(grep '^distributionUrl=' "${PROPS_FILE}" | cut -d= -f2-)
  DISTRIBUTION_SHA=$(grep '^distributionSha256Sum=' "${PROPS_FILE}" | cut -d= -f2-)
else
  echo "ERROR: No se encontró ${PROPS_FILE}" >&2
  exit 1
fi

# Directorio de distribución en ~/.m2/wrapper/dists
DISTRIBUTION_NAME=$(basename "${DISTRIBUTION_URL}" .zip)
WRAPPER_DIR="${HOME}/.m2/wrapper/dists/${DISTRIBUTION_NAME}"
MAVEN_HOME="${WRAPPER_DIR}/unzipped/${DISTRIBUTION_NAME}"

# Descargar si no existe
if [ ! -d "${MAVEN_HOME}" ]; then
  mkdir -p "${WRAPPER_DIR}/unzipped"
  ZIP_FILE="${WRAPPER_DIR}/${DISTRIBUTION_NAME}.zip"

  echo "Descargando Maven desde ${DISTRIBUTION_URL} ..."
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "${DISTRIBUTION_URL}" -o "${ZIP_FILE}"
  elif command -v wget >/dev/null 2>&1; then
    wget -q -O "${ZIP_FILE}" "${DISTRIBUTION_URL}"
  else
    echo "ERROR: necesitas curl o wget para descargar Maven." >&2
    exit 1
  fi

  # Verificar SHA256 si está disponible
  if [ -n "${DISTRIBUTION_SHA}" ]; then
    if command -v sha256sum >/dev/null 2>&1; then
      echo "${DISTRIBUTION_SHA}  ${ZIP_FILE}" | sha256sum --check --quiet \
        || { echo "ERROR: checksum SHA256 no coincide" >&2; rm -f "${ZIP_FILE}"; exit 1; }
    elif command -v shasum >/dev/null 2>&1; then
      echo "${DISTRIBUTION_SHA}  ${ZIP_FILE}" | shasum -a 256 --check --quiet \
        || { echo "ERROR: checksum SHA256 no coincide" >&2; rm -f "${ZIP_FILE}"; exit 1; }
    fi
  fi

  unzip -q "${ZIP_FILE}" -d "${WRAPPER_DIR}/unzipped"
  rm -f "${ZIP_FILE}"
  echo "Maven instalado en ${MAVEN_HOME}"
fi

# Ejecutar Maven
exec "${MAVEN_HOME}/bin/mvn" "$@"
