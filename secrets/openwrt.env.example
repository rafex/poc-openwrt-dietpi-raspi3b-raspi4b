# secrets/openwrt.env.example — Plantilla de credenciales WiFi para el router OpenWrt
#
# INSTRUCCIONES:
#   1. Copia este archivo:
#        cp secrets/openwrt.env.example secrets/openwrt.env
#   2. Edita secrets/openwrt.env con los valores reales
#   3. Sube el archivo al router:
#        scp secrets/openwrt.env root@192.168.1.1:/etc/wifi-repeater.env
#        ssh root@192.168.1.1 "chmod 600 /etc/wifi-repeater.env"
#   4. Ejecuta el script en el router:
#        sh setup_wifi_repeater.sh
#        # o pasando la ruta explícita:
#        sh setup_wifi_repeater.sh --env-file /etc/wifi-repeater.env
#
# SEGURIDAD:
#   - secrets/openwrt.env está en .gitignore — nunca va al repositorio
#   - En el router: chmod 600 /etc/wifi-repeater.env
#   - Este archivo (.example) SÍ va al repo — solo tiene valores ficticios
#
# FORMATO:
#   - Sin espacios alrededor del =
#   - Comillas obligatorias si el valor contiene espacios o caracteres especiales
#   - Compatibilidad POSIX sh (BusyBox) — sin arrays, sin $()

# ── Red de casa (cliente STA) ─────────────────────────────────────────────────
# SSID y contraseña de la red WiFi a la que el router se conecta como cliente.
HOME_SSID="MiCasa_WiFi"
HOME_PASS="contraseña_de_casa"

# ── AP que expone el router ───────────────────────────────────────────────────
# SSID y contraseña del punto de acceso que el router crea para los clientes.
AP_SSID="OpenWrt-Portal"
AP_PASS="contraseña_del_ap"

# ── Radios (opcional — autodetectado por wifi status si se omite) ─────────────
# Descomenta solo si la autodetección falla en tu hardware.
# WIFI_STA="radio0"   # radio para el cliente STA (hacia casa)
# WIFI_AP="radio1"    # radio para el AP (para clientes)
