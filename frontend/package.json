{
  "name": "ai-analyzer-frontend",
  "version": "1.0.0",
  "description": "Frontend para AI Analyzer — Red WiFi con IA (Pug + Sass + TypeScript + Vite)",
  "private": true,
  "scripts": {
    "pug":          "pug src/pug/pages/ --out . --basedir src/pug --pretty",
    "pug:watch":    "pug src/pug/pages/ --out . --basedir src/pug --pretty --watch",
    "prebuild":     "npm run pug",
    "build":        "vite build",
    "preview":      "vite preview --port 4173",
    "dev":          "concurrently --kill-others \"npm run pug:watch\" \"vite\"",
    "typecheck":    "tsc --noEmit"
  },
  "devDependencies": {
    "concurrently":    "^8.2.2",
    "pug":             "^3.0.3",
    "pug-cli":         "^1.0.0-alpha6",
    "sass":            "^1.77.0",
    "typescript":      "^5.4.0",
    "vite":            "^5.4.0",
    "@types/node":     "^20.0.0"
  },
  "dependencies": {
    "animate.css": "^4.1.1"
  }
}
