# Topología de despliegue de la PoC.
# Copiar a /etc/demo-openwrt/topology.env para override local por host.

# legacy:
#   OpenWrt -> Sensor(3B#1) -> AI+k3s+Portal(4B)
# split_portal:
#   OpenWrt -> Portal node(3B#2) + Sensor(3B#1) -> AI+k3s(4B)
TOPOLOGY=legacy

ROUTER_IP=192.168.1.1
ADMIN_IP=192.168.1.113
LAN_SUBNET=192.168.1.0/24

RASPI4B_IP=192.168.1.167
RASPI4B_MAC=d8:3a:dd:4d:4b:ae
RASPI4B_HOSTNAME=RafexPi4B

RASPI3B_IP=192.168.1.181
RASPI3B_MAC=b8:27:eb:5a:ec:33
RASPI3B_HOSTNAME=RafexPi3B

# Raspi 3B #2 (portal node alternativo)
PORTAL_NODE_IP=192.168.1.182
PORTAL_NODE_MAC=b8:27:eb:2e:fc:f2
PORTAL_NODE_HOSTNAME=RafexPi3BPortal

# AP extra para expandir señal (debe tener bypass permanente del portal)
AP_EXTENDER_IP=192.168.1.183
AP_EXTENDER_MAC=E8:DE:27:99:B7:57
AP_EXTENDER_HOSTNAME=RafexAPExtender

# IP del nodo de IA (ai-analyzer + llama.cpp)
AI_IP=192.168.1.167

# En legacy normalmente igual a AI_IP.
# En split_portal normalmente igual a PORTAL_NODE_IP.
PORTAL_IP=192.168.1.167

CAPTIVE_DOMAIN=captive.localhost.com
PEOPLE_DOMAIN=people.localhost.com

PORTAL_TIMEOUT=120m
